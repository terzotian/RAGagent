# Copy to .env for local development (DO NOT COMMIT .env)

# Vertex AI
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Option A: Application Default Credentials (recommended)
# Point this to a local service account JSON on your machine.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service_account.json

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/lurag

# Optional: local data root override
# LOCAL_DATA_DIR=/absolute/path/to/.local_data
